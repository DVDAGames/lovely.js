  "bugs": {
    "url": "https://github.com/DVDAGames/lovely.js/issues"
  },
  "homepage": "https://github.com/DVDAGames/lovely.js#readme",
  "files": [
    "dist",
    "docs",
    "scripts"
  ],
  "devDependencies": {
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-love": "^154.0.0",
    "typescript": "^5.9.3"
  }
}
