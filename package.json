{
  "name": "@dvdagames/lovely.js",
  "version": "0.1.0",
  "description": "Patched LÖVE web runtime bundles for Lovely.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node --experimental-strip-types scripts/package-runtime.ts",
    "lint": "eslint .",
