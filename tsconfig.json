{
  "compilerOptions": {
    "allowJs": true,
    "declaration": false,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"]
  },
  "include": [
    "eslint.config.js",
    "scripts/**/*.ts"
  ]
}
